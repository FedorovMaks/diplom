# Supabase Postgres connection string
# Получить в Supabase Dashboard → Settings → Database → Connection string (URI / Transaction mode)
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Учётные данные администратора (используются только для входа в /admin)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=changeme

# Случайная длинная строка для подписи сессионной cookie (>= 32 символа)
SESSION_SECRET=replace-me-with-a-long-random-string

# Порт HTTP-сервера
PORT=3000
